import Std::Io::{PrintLine};

struct JsonArray {
    data: **JsonValue,
    len: uint,
    cap: uint
}

struct JsonObjectEntry {
    key: String,
    value: *JsonValue
}

struct JsonObject {
    data: *JsonObjectEntry,
    len: uint,
    cap: uint
}

enum JsonValue {
    JsonNull,
    JsonBool(bool),
    JsonNumber(float64),
    JsonString(String),
    JsonArray(JsonArray),
    JsonObject(JsonObject)
}

func Main() -> int {
    let v: JsonValue = JsonValue { tag: JsonValue_JsonNull };
    PrintLine("ok");
    return 0;
}
