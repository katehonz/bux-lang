import Std::Io::{PrintLine};

struct JsonValue {
    tag: int,
    boolVal: bool,
    numVal: float64,
    strVal: String,
    arrData: *JsonValue,
    arrLen: uint,
    objKeys: *String,
    objValues: *JsonValue,
    objLen: uint
}

func Main() -> int {
    let v: JsonValue = JsonValue { tag: 0, boolVal: false, numVal: 0.0, strVal: "hello", arrData: null, arrLen: 0, objKeys: null, objValues: null, objLen: 0 };
    PrintLine(v.strVal);
    return 0;
}
