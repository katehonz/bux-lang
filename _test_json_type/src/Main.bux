import Std::Io::{PrintLine};
import Std::Array::{Array};

enum JsonValue {
    JsonNull,
    JsonBool(bool),
    JsonNumber(float64),
    JsonString(String),
    JsonArray(Array<JsonValue>),
    JsonObject(Map<String, JsonValue>)
}

func Main() -> int {
    let v: JsonValue = JsonValue { tag: JsonNull };
    PrintLine("ok");
    return 0;
}
