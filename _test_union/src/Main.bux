import Std::Io::{PrintLine};

union JsonData {
    boolVal: bool,
    numVal: float64,
    strVal: String
}

struct JsonValue {
    tag: int,
    data: JsonData
}

func Main() -> int {
    let v: JsonValue = JsonValue { tag: 0, data: JsonData { strVal: "hello" } };
    PrintLine(v.data.strVal);
    return 0;
}
