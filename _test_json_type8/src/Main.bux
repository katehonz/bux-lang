import Std::Io::{PrintLine};

struct JsonArray {
    data: *JsonValue,
    len: uint,
    cap: uint
}

enum JsonValue {
    JsonNull,
    JsonBool(bool),
    JsonNumber(float64),
    JsonString(String),
    JsonArrayPtr(*JsonArray)
}

func Main() -> int {
    let v: JsonValue = JsonValue { tag: JsonValue_JsonNull };
    PrintLine("ok");
    return 0;
}
