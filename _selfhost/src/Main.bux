src_bux/types.bux:struct Type {
src_bux/types.bux:    kind: int,
src_bux/types.bux:    name: String,
src_bux/types.bux:    // inner types stored as array of pointers (simplified)
src_bux/types.bux:    innerKind1: int,
src_bux/types.bux:    innerName1: String,
