module BuxC {
src_bux/source_location.bux:// source_location.bux — Source position tracking
src_bux/source_location.bux:
src_bux/source_location.bux:struct SourceLocation {
src_bux/source_location.bux:    line: uint32,
src_bux/source_location.bux:    column: uint32,
src_bux/source_location.bux:    offset: uint32,
src_bux/source_location.bux:}
src_bux/source_location.bux:
src_bux/source_location.bux:func SourceLocation_New(line: uint32, column: uint32, offset: uint32) -> SourceLocation {
src_bux/source_location.bux:    return SourceLocation { line: line, column: column, offset: offset };
src_bux/source_location.bux:}
