src_bux/types.bux:// Predicates
src_bux/types.bux:// ---------------------------------------------------------------------------
src_bux/types.bux:
src_bux/types.bux:func Type_IsNumeric(t: Type) -> bool {
src_bux/types.bux:    let k: int = t.kind;
src_bux/types.bux:    if k == tkInt8 || k == tkInt16 || k == tkInt32 || k == tkInt64 || k == tkInt { return true; }
src_bux/types.bux:    if k == tkUInt8 || k == tkUInt16 || k == tkUInt32 || k == tkUInt64 || k == tkUInt { return true; }
src_bux/types.bux:    if k == tkFloat32 || k == tkFloat64 { return true; }
src_bux/types.bux:    if k == tkUnknown || k == tkNamed || k == tkTypeParam { return true; }
src_bux/types.bux:    return false;
src_bux/types.bux:}
src_bux/types.bux:
src_bux/types.bux:func Type_IsInteger(t: Type) -> bool {
src_bux/types.bux:    let k: int = t.kind;
src_bux/types.bux:    if k == tkInt8 || k == tkInt16 || k == tkInt32 || k == tkInt64 || k == tkInt { return true; }
src_bux/types.bux:    if k == tkUInt8 || k == tkUInt16 || k == tkUInt32 || k == tkUInt64 || k == tkUInt { return true; }
src_bux/types.bux:    if k == tkUnknown || k == tkNamed || k == tkTypeParam { return true; }
src_bux/types.bux:    return false;
src_bux/types.bux:}
src_bux/types.bux:
src_bux/types.bux:func Type_IsBool(t: Type) -> bool {
src_bux/types.bux:    let k: int = t.kind;
src_bux/types.bux:    return k == tkBool || k == tkBool8 || k == tkBool16 || k == tkBool32;
src_bux/types.bux:}
src_bux/types.bux:
src_bux/types.bux:func Type_IsPointer(t: Type) -> bool {
src_bux/types.bux:    return t.kind == tkPointer;
src_bux/types.bux:}
src_bux/types.bux:
src_bux/types.bux:func Type_IsSlice(t: Type) -> bool {
src_bux/types.bux:    return t.kind == tkSlice;
src_bux/types.bux:}
src_bux/types.bux:
src_bux/types.bux:// ---------------------------------------------------------------------------
src_bux/types.bux:// Comparison (structural, limited to kind + name for simplicity)
src_bux/types.bux:// ---------------------------------------------------------------------------
src_bux/types.bux:
src_bux/types.bux:func Type_Eq(a: Type, b: Type) -> bool {
src_bux/types.bux:    if a.kind != b.kind { return false; }
src_bux/types.bux:    if a.kind == tkNamed || a.kind == tkTypeParam {
src_bux/types.bux:        return String_Eq(a.name, b.name);
src_bux/types.bux:    }
src_bux/types.bux:    return true;
src_bux/types.bux:}
src_bux/types.bux:
src_bux/types.bux:// ---------------------------------------------------------------------------
src_bux/types.bux:// toString
src_bux/types.bux:// ---------------------------------------------------------------------------
src_bux/types.bux:
src_bux/types.bux:func Type_ToString(t: Type) -> String {
src_bux/types.bux:    if t.kind == tkVoid { return "void"; }
src_bux/types.bux:    if t.kind == tkBool { return "bool"; }
src_bux/types.bux:    if t.kind == tkStr { return "String"; }
src_bux/types.bux:    if t.kind == tkInt { return "int"; }
src_bux/types.bux:    if t.kind == tkInt64 { return "int64"; }
src_bux/types.bux:    if t.kind == tkUInt { return "uint"; }
src_bux/types.bux:    if t.kind == tkFloat64 { return "float64"; }
src_bux/types.bux:    if t.kind == tkNamed { return t.name; }
src_bux/types.bux:    if t.kind == tkTypeParam { return t.name; }
src_bux/types.bux:    if t.kind == tkPointer { return "*" + t.innerName1; }
src_bux/types.bux:    return "?";
src_bux/types.bux:}
src_bux/scope.bux:// scope.bux — Symbol table with parent-chain lookup
src_bux/scope.bux:
src_bux/scope.bux:// Symbol kinds
src_bux/scope.bux:const skVar: int = 0;
src_bux/scope.bux:const skFunc: int = 1;
src_bux/scope.bux:const skType: int = 2;
src_bux/scope.bux:const skConst: int = 3;
src_bux/scope.bux:const skModule: int = 4;
src_bux/scope.bux:
src_bux/scope.bux:// Maximum symbols per scope
src_bux/scope.bux:const maxSymbols: int = 256;
src_bux/scope.bux:
src_bux/scope.bux:struct Symbol {
src_bux/scope.bux:    kind: int,
src_bux/scope.bux:    name: String,
src_bux/scope.bux:    typeKind: int,
src_bux/scope.bux:    typeName: String,
src_bux/scope.bux:    isMutable: bool,
src_bux/scope.bux:    isPublic: bool,
src_bux/scope.bux:}
src_bux/scope.bux:
src_bux/scope.bux:struct Scope {
src_bux/scope.bux:    symbols: *Symbol,
src_bux/scope.bux:    count: int,
src_bux/scope.bux:    parent: *Scope,
src_bux/scope.bux:}
src_bux/scope.bux:
src_bux/scope.bux:// ---------------------------------------------------------------------------
src_bux/scope.bux:// Scope operations
src_bux/scope.bux:// ---------------------------------------------------------------------------
src_bux/scope.bux:
src_bux/scope.bux:func Scope_New() -> Scope {
src_bux/scope.bux:    let sz: uint = maxSymbols as uint * sizeof(Symbol);
src_bux/scope.bux:    let data: *Symbol = bux_alloc(sz) as *Symbol;
src_bux/scope.bux:    return Scope { symbols: data, count: 0, parent: null as *Scope };
src_bux/scope.bux:}
src_bux/scope.bux:
src_bux/scope.bux:func Scope_NewChild(parent: *Scope) -> Scope {
src_bux/scope.bux:    let sz: uint = maxSymbols as uint * sizeof(Symbol);
src_bux/scope.bux:    let data: *Symbol = bux_alloc(sz) as *Symbol;
src_bux/scope.bux:    return Scope { symbols: data, count: 0, parent: parent };
src_bux/scope.bux:}
src_bux/scope.bux:
src_bux/scope.bux:func Scope_Define(scope: *Scope, sym: Symbol) -> bool {
src_bux/scope.bux:    // Check local scope for duplicates
src_bux/scope.bux:    var i: int = 0;
src_bux/scope.bux:    while i < scope.count {
src_bux/scope.bux:        if String_Eq(scope.symbols[i].name, sym.name) {
src_bux/scope.bux:            return false;
src_bux/scope.bux:        }
src_bux/scope.bux:        i = i + 1;
src_bux/scope.bux:    }
src_bux/scope.bux:    if scope.count < maxSymbols {
src_bux/scope.bux:        scope.symbols[scope.count] = sym;
src_bux/scope.bux:        scope.count = scope.count + 1;
src_bux/scope.bux:        return true;
src_bux/scope.bux:    }
src_bux/scope.bux:    return false;
src_bux/scope.bux:}
src_bux/scope.bux:
src_bux/scope.bux:func Scope_Lookup(scope: *Scope, name: String) -> Symbol {
src_bux/scope.bux:    var cur: *Scope = scope;
src_bux/scope.bux:    while cur != null as *Scope {
src_bux/scope.bux:        var i: int = 0;
src_bux/scope.bux:        while i < cur.count {
src_bux/scope.bux:            if String_Eq(cur.symbols[i].name, name) {
src_bux/scope.bux:                return cur.symbols[i];
src_bux/scope.bux:            }
src_bux/scope.bux:            i = i + 1;
src_bux/scope.bux:        }
src_bux/scope.bux:        cur = cur.parent;
src_bux/scope.bux:    }
src_bux/scope.bux:    var empty: Symbol;
src_bux/scope.bux:    return empty;
src_bux/scope.bux:}
src_bux/scope.bux:
src_bux/scope.bux:func Scope_LookupLocal(scope: *Scope, name: String) -> Symbol {
src_bux/scope.bux:    var i: int = 0;
src_bux/scope.bux:    while i < scope.count {
src_bux/scope.bux:        if String_Eq(scope.symbols[i].name, name) {
src_bux/scope.bux:            return scope.symbols[i];
src_bux/scope.bux:        }
src_bux/scope.bux:        i = i + 1;
src_bux/scope.bux:    }
src_bux/scope.bux:    var empty: Symbol;
src_bux/scope.bux:    return empty;
src_bux/scope.bux:}
src_bux/scope.bux:
src_bux/scope.bux:func Scope_Free(scope: *Scope) {
src_bux/scope.bux:    bux_free(scope.symbols as *void);
src_bux/scope.bux:}
}
func Main() -> int { return 0; }
