src_bux/token.bux:
src_bux/token.bux:func Token_IsKeyword(kind: int) -> bool {
src_bux/token.bux:    if kind >= tkIf && kind <= tkIn { return true; }
src_bux/token.bux:    if kind >= tkBreak && kind <= tkMatch { return true; }
src_bux/token.bux:    if kind >= tkFunc && kind <= tkExtern { return true; }
src_bux/token.bux:    if kind >= tkAs && kind <= tkSuper { return true; }
src_bux/token.bux:    return false;
src_bux/token.bux:}
src_bux/token.bux:
src_bux/token.bux:func Token_IsLiteral(kind: int) -> bool {
src_bux/token.bux:    if kind >= tkIntLiteral && kind <= tkBoolLiteral { return true; }
src_bux/token.bux:    return false;
src_bux/token.bux:}
src_bux/token.bux:
src_bux/token.bux:func Token_IsOperator(kind: int) -> bool {
src_bux/token.bux:    if kind >= tkPlus && kind <= tkShrAssign { return true; }
src_bux/token.bux:    return false;
src_bux/token.bux:}
src_bux/token.bux:
src_bux/token.bux:func Token_IsEof(kind: int) -> bool {
src_bux/token.bux:    return kind == tkEndOfFile;
src_bux/token.bux:}
src_bux/token.bux:
src_bux/token.bux:func Token_KeywordKind(text: String) -> int {
src_bux/token.bux:    if String_Eq(text, "func") { return tkFunc; }
src_bux/token.bux:    if String_Eq(text, "let") { return tkLet; }
src_bux/token.bux:    if String_Eq(text, "var") { return tkVar; }
src_bux/token.bux:    if String_Eq(text, "const") { return tkConst; }
src_bux/token.bux:    if String_Eq(text, "type") { return tkType; }
src_bux/token.bux:    if String_Eq(text, "struct") { return tkStruct; }
src_bux/token.bux:    if String_Eq(text, "enum") { return tkEnum; }
src_bux/token.bux:    if String_Eq(text, "union") { return tkUnion; }
src_bux/token.bux:    if String_Eq(text, "interface") { return tkInterface; }
src_bux/token.bux:    if String_Eq(text, "extend") { return tkExtend; }
src_bux/token.bux:    if String_Eq(text, "module") { return tkModule; }
src_bux/token.bux:    if String_Eq(text, "import") { return tkImport; }
src_bux/token.bux:    if String_Eq(text, "pub") { return tkPub; }
src_bux/token.bux:    if String_Eq(text, "extern") { return tkExtern; }
src_bux/token.bux:    if String_Eq(text, "if") { return tkIf; }
src_bux/token.bux:    if String_Eq(text, "else") { return tkElse; }
src_bux/token.bux:    if String_Eq(text, "while") { return tkWhile; }
src_bux/token.bux:    if String_Eq(text, "do") { return tkDo; }
src_bux/token.bux:    if String_Eq(text, "loop") { return tkLoop; }
src_bux/token.bux:    if String_Eq(text, "for") { return tkFor; }
src_bux/token.bux:    if String_Eq(text, "in") { return tkIn; }
src_bux/token.bux:    if String_Eq(text, "break") { return tkBreak; }
src_bux/token.bux:    if String_Eq(text, "continue") { return tkContinue; }
src_bux/token.bux:    if String_Eq(text, "return") { return tkReturn; }
src_bux/token.bux:    if String_Eq(text, "match") { return tkMatch; }
src_bux/token.bux:    if String_Eq(text, "as") { return tkAs; }
src_bux/token.bux:    if String_Eq(text, "is") { return tkIs; }
src_bux/token.bux:    if String_Eq(text, "null") { return tkNull; }
src_bux/token.bux:    if String_Eq(text, "self") { return tkSelf; }
src_bux/token.bux:    if String_Eq(text, "super") { return tkSuper; }
src_bux/token.bux:    if String_Eq(text, "sizeof") { return tkSizeOf; }
src_bux/token.bux:    if String_Eq(text, "true") { return tkBoolLiteral; }
src_bux/token.bux:    if String_Eq(text, "false") { return tkBoolLiteral; }
src_bux/token.bux:    return tkIdent;
src_bux/token.bux:}
src_bux/token.bux:
src_bux/token.bux:func Token_KindName(kind: int) -> String {
src_bux/token.bux:    if kind == tkIntLiteral { return "integer literal"; }
src_bux/token.bux:    if kind == tkFloatLiteral { return "float literal"; }
src_bux/token.bux:    if kind == tkStringLiteral { return "string literal"; }
src_bux/token.bux:    if kind == tkCharLiteral { return "char literal"; }
src_bux/token.bux:    if kind == tkBoolLiteral { return "boolean literal"; }
src_bux/token.bux:    if kind == tkIdent { return "identifier"; }
src_bux/token.bux:    if kind == tkUnderscore { return "_"; }
src_bux/token.bux:    if kind == tkSizeOf { return "sizeof"; }
src_bux/token.bux:    if kind == tkIf { return "if"; }
src_bux/token.bux:    if kind == tkElse { return "else"; }
src_bux/token.bux:    if kind == tkWhile { return "while"; }
src_bux/token.bux:    if kind == tkDo { return "do"; }
src_bux/token.bux:    if kind == tkLoop { return "loop"; }
src_bux/token.bux:    if kind == tkFor { return "for"; }
src_bux/token.bux:    if kind == tkIn { return "in"; }
src_bux/token.bux:    if kind == tkBreak { return "break"; }
src_bux/token.bux:    if kind == tkContinue { return "continue"; }
src_bux/token.bux:    if kind == tkReturn { return "return"; }
src_bux/token.bux:    if kind == tkMatch { return "match"; }
src_bux/token.bux:    if kind == tkFunc { return "func"; }
src_bux/token.bux:    if kind == tkLet { return "let"; }
src_bux/token.bux:    if kind == tkVar { return "var"; }
src_bux/token.bux:    if kind == tkConst { return "const"; }
src_bux/token.bux:    if kind == tkType { return "type"; }
src_bux/token.bux:    if kind == tkStruct { return "struct"; }
src_bux/token.bux:    if kind == tkEnum { return "enum"; }
src_bux/token.bux:    if kind == tkUnion { return "union"; }
src_bux/token.bux:    if kind == tkInterface { return "interface"; }
src_bux/token.bux:    if kind == tkExtend { return "extend"; }
src_bux/token.bux:    if kind == tkModule { return "module"; }
src_bux/token.bux:    if kind == tkImport { return "import"; }
src_bux/token.bux:    if kind == tkPub { return "pub"; }
src_bux/token.bux:    if kind == tkExtern { return "extern"; }
src_bux/token.bux:    if kind == tkAs { return "as"; }
src_bux/token.bux:    if kind == tkIs { return "is"; }
src_bux/token.bux:    if kind == tkNull { return "null"; }
src_bux/token.bux:    if kind == tkSelf { return "self"; }
src_bux/token.bux:    if kind == tkSuper { return "super"; }
src_bux/token.bux:    if kind == tkLParen { return "("; }
src_bux/token.bux:    if kind == tkRParen { return ")"; }
src_bux/token.bux:    if kind == tkLBrace { return "{"; }
src_bux/token.bux:    if kind == tkRBrace { return "}"; }
src_bux/token.bux:    if kind == tkLBracket { return "["; }
src_bux/token.bux:    if kind == tkRBracket { return "]"; }
src_bux/token.bux:    if kind == tkComma { return ","; }
src_bux/token.bux:    if kind == tkSemicolon { return ";"; }
src_bux/token.bux:    if kind == tkColon { return ":"; }
src_bux/token.bux:    if kind == tkColonColon { return "::"; }
src_bux/token.bux:    if kind == tkDot { return "."; }
src_bux/token.bux:    if kind == tkDotDot { return ".."; }
src_bux/token.bux:    if kind == tkDotDotDot { return "..."; }
src_bux/token.bux:    if kind == tkDotDotEqual { return "..="; }
src_bux/token.bux:    if kind == tkArrow { return "->"; }
src_bux/token.bux:    if kind == tkFatArrow { return "=>"; }
src_bux/token.bux:    if kind == tkAt { return "@"; }
src_bux/token.bux:    if kind == tkHash { return "#"; }
src_bux/token.bux:    if kind == tkQuestion { return "?"; }
src_bux/token.bux:    if kind == tkPlus { return "+"; }
src_bux/token.bux:    if kind == tkMinus { return "-"; }
src_bux/token.bux:    if kind == tkStar { return "*"; }
src_bux/token.bux:    if kind == tkSlash { return "/"; }
src_bux/token.bux:    if kind == tkPercent { return "%"; }
src_bux/token.bux:    if kind == tkStarStar { return "**"; }
src_bux/token.bux:    if kind == tkPlusPlus { return "++"; }
src_bux/token.bux:    if kind == tkMinusMinus { return "--"; }
src_bux/token.bux:    if kind == tkAmp { return "&"; }
src_bux/token.bux:    if kind == tkPipe { return "|"; }
src_bux/token.bux:    if kind == tkCaret { return "^"; }
src_bux/token.bux:    if kind == tkTilde { return "~"; }
src_bux/token.bux:    if kind == tkShl { return "<<"; }
src_bux/token.bux:    if kind == tkShr { return ">>"; }
src_bux/token.bux:    if kind == tkAmpAmp { return "&&"; }
src_bux/token.bux:    if kind == tkPipePipe { return "||"; }
src_bux/token.bux:    if kind == tkBang { return "!"; }
src_bux/token.bux:    if kind == tkEq { return "=="; }
src_bux/token.bux:    if kind == tkNe { return "!="; }
src_bux/token.bux:    if kind == tkLt { return "<"; }
src_bux/token.bux:    if kind == tkLe { return "<="; }
src_bux/token.bux:    if kind == tkGt { return ">"; }
src_bux/token.bux:    if kind == tkGe { return ">="; }
src_bux/token.bux:    if kind == tkAssign { return "="; }
src_bux/token.bux:    if kind == tkPlusAssign { return "+="; }
src_bux/token.bux:    if kind == tkMinusAssign { return "-="; }
src_bux/token.bux:    if kind == tkStarAssign { return "*="; }
src_bux/token.bux:    if kind == tkSlashAssign { return "/="; }
src_bux/token.bux:    if kind == tkPercentAssign { return "%="; }
src_bux/token.bux:    if kind == tkAmpAssign { return "&="; }
src_bux/token.bux:    if kind == tkPipeAssign { return "|="; }
src_bux/token.bux:    if kind == tkCaretAssign { return "^="; }
src_bux/token.bux:    if kind == tkShlAssign { return "<<="; }
src_bux/token.bux:    if kind == tkShrAssign { return ">>="; }
src_bux/token.bux:    if kind == tkHashLine { return "#line"; }
src_bux/token.bux:    if kind == tkHashColumn { return "#column"; }
src_bux/token.bux:    if kind == tkHashFile { return "#file"; }
src_bux/token.bux:    if kind == tkHashFunction { return "#function"; }
src_bux/token.bux:    if kind == tkHashDate { return "#date"; }
src_bux/token.bux:    if kind == tkHashTime { return "#time"; }
src_bux/token.bux:    if kind == tkHashModule { return "#module"; }
src_bux/token.bux:    if kind == tkNewLine { return "newline"; }
src_bux/token.bux:    if kind == tkEndOfFile { return "end of file"; }
src_bux/token.bux:    return "unknown token";
src_bux/token.bux:}
